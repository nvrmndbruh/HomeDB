<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HomeDB.ItemListPage"
             Title="Выберите вещь"
             xmlns:vm="clr-namespace:HomeDB.ViewModels"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome">
    <ContentPage.BindingContext>
        <vm:ItemListViewModel/>
    </ContentPage.BindingContext>


    <Border Grid.Row="1" Margin="30" Padding="16">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20"/>
        </Border.StrokeShape>
        <CollectionView ItemsSource="{Binding Nodes, Mode=TwoWay}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Image Source="{Binding Icon}" WidthRequest="25" Grid.Column="0"/>
                        <Label Text="{Binding Name}" VerticalOptions="Center" FontSize="20" Grid.Column="1" Padding="10"/>

                        <Button ImageSource="{FontImageSource FontFamily=FASolid, Glyph={x:Static fa:Solid.Check}, Color={StaticResource SummerGreen}, Size=24}" 
                                Scale="0.7"
                                Grid.Column="2"
                                HorizontalOptions="End"
                                CornerRadius="10"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ItemListViewModel}}, Path=SelectCommand}"
                                CommandParameter="{Binding .}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Border>
</ContentPage>