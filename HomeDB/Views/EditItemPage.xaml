<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HomeDB.EditItemPage"
             xmlns:vm="clr-namespace:HomeDB.ViewModels"
             xmlns:converter="clr-namespace:HomeDB.Converters"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             Title="Редактирование вещи">

    <ContentPage.BindingContext>
        <vm:EditItemViewModel/>
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="30, 0, 30, 20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditItemViewModel}}, Path=SelectPhotoCommand}"/>
            </Border.GestureRecognizers>
            <Image Source="{Binding Photo, Converter={StaticResource NullToStringConverter}}"/>
        </Border>

        <Label Grid.Row="0" Text="+" FontSize="80" IsVisible="{Binding Photo, Converter={StaticResource StringToVisibilityConverter}}"
               TextColor="{StaticResource DarkEbony}"
               VerticalOptions="Center" HorizontalOptions="Center"/>

        <ScrollView Grid.Row="1">
            <StackLayout Padding="30, 0, 30, 0" VerticalOptions="Start" Grid.Row="1" Spacing="20">
                <Entry Text="{Binding Item.Name, Mode=TwoWay}" FontSize="20" FontAttributes="Bold" Placeholder="Название"/>

                <Editor Text="{Binding Item.Description, Mode=TwoWay, Converter={StaticResource NullToStringConverter}}" Placeholder="Описание"/>

                <StackLayout>
                    <Label Text="Иконка"/>
                    <Grid ColumnSpacing="10" Padding="2, 5, 0, 5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" HeightRequest="40" BindingContext="{x:Reference IconPicker}" Source="{Binding SelectedItem}"/>
                        <Picker Grid.Column="1" x:Name="IconPicker" SelectedItem="{Binding Item.Icon}">
                            <Picker.Items>
                                <x:String>it_abstract.png</x:String>
                                <x:String>thirt.png</x:String>
                                <x:String>plug.png</x:String>
                            </Picker.Items>
                        </Picker>
                    </Grid>
                </StackLayout>

                <StackLayout>
                    <Label Text="Цена"/>
                    <Entry Text="{Binding PriceInput, Mode=TwoWay, Converter={StaticResource NullToStringConverter}}" Placeholder="0.0"/>
                </StackLayout>
                
            </StackLayout>
        </ScrollView>

        <Grid Grid.Row="2" Padding="20, 0, 20, 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Margin="8"
                    Grid.Column="0"
                    Text="СОХРАНИТЬ"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditContainerViewModel}}, Path=SaveCommand}"/>

            <Button Margin="8"
                    TextColor="{StaticResource PaleMagenta}"
                    Grid.Column="1"
                    Text="УДАЛИТЬ"
                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:EditContainerViewModel}}, Path=DeleteCommand}"/>
        </Grid>

    </Grid>
</ContentPage>