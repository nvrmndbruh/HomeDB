<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HomeDB.CategoryPage"
             Title="Категории"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:vm="clr-namespace:HomeDB.ViewModels"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome">
    
    <ContentPage.BindingContext>
        <vm:CategoryViewModel/>
    </ContentPage.BindingContext>

    <AbsoluteLayout>
        <ScrollView Orientation="Both">
            <material:TreeView
                ItemsSource="{Binding Nodes}"
                IsLeafPropertyName="IsLeaf"
                LoadChildrenCommand="{Binding LoadChildrenCommand}"
                Padding="10"
                SelectionMode="Single"
                SelectedItem="{Binding SelectedNode}">
                <material:TreeView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0" Source="{Binding Icon}" HeightRequest="30"/>
                            <Label Grid.Column="1" Text="{Binding Name}" VerticalOptions="Center" FontSize="30"/>
                        </Grid>
                    </DataTemplate>
                </material:TreeView.ItemTemplate>
            </material:TreeView>
        </ScrollView>
        
        <Button Text="+" 
            FontSize="30"
            HeightRequest="60"
            WidthRequest="60"
            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryViewModel}}, Path=AddCommand}"
            AbsoluteLayout.LayoutBounds="340, 700, AutoSize, AutoSize"/>

        <Button ImageSource="{FontImageSource FontFamily=FASolid, Glyph={x:Static fa:Solid.Pen}, Color={StaticResource SummerGreen}}"
            FontSize="25"
            HeightRequest="50"
            WidthRequest="50"
            IsVisible="{Binding SelectedNode, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='reverse'}"
            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoryViewModel}}, Path=EditCommand}"
            AbsoluteLayout.LayoutBounds="350, 635, AutoSize, AutoSize"/>

    </AbsoluteLayout>
</ContentPage>